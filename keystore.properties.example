# ── keystore.properties.example ─────────────────────────────────────────────
# Copy this file to "keystore.properties" (in the same folder) and fill in your values.
# keystore.properties is listed in .gitignore — NEVER commit it to git.
#
# STEP 1 — Generate your keystore (run once from the project root folder):
#   keytool -genkey -v -keystore android.keystore -alias expensioapp -keyalg RSA -keysize 2048 -validity 10000
#
# STEP 2 — Get your SHA-256 fingerprint (needed for assetlinks.json):
#   keytool -list -v -keystore android.keystore -alias expensioapp
#   Copy the "SHA256:" line — it looks like: AB:12:CD:34:...
#
# STEP 3 — Fill in the values below and save as keystore.properties
# ─────────────────────────────────────────────────────────────────────────────

storeFile=../android.keystore
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=expensioapp
keyPassword=YOUR_KEY_PASSWORD
